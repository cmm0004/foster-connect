<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clinical_bg"
    android:orientation="vertical">

    <!-- App bar -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/clinical_line" />

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Scan banner -->
            <LinearLayout
                android:id="@+id/banner_scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_scan_banner"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="11dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="Scan"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/clinical_amber" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan foster agreement"
                        android:textColor="@color/clinical_amber"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:fontFamily="monospace"
                        android:text="Auto-fill litter name, breed &amp; intake date"
                        android:textColor="@color/clinical_ink_muted"
                        android:textSize="9sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=">"
                    android:textColor="@color/clinical_amber"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Litter info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/clinical_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Section header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_kitten_card_header"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:text="LITTER INFO · SHARED ACROSS ALL FOSTERS"
                        android:textColor="@color/clinical_ink_muted"
                        android:textSize="10sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/clinical_line" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="12dp">

                        <!-- Litter name + intake date row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.4"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/MedFieldLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LITTER NAME" />

                                <EditText
                                    android:id="@+id/input_litter_name"
                                    style="@style/MedTextInput"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="e.g. Spring Batch A"
                                    android:inputType="textCapWords"
                                    android:importantForAutofill="no" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/MedFieldLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="INTAKE DATE" />

                                <TextView
                                    android:id="@+id/input_intake_date"
                                    style="@style/MedDateButton"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="MM / DD / YY"
                                    android:textColorHint="@color/clinical_ink_muted" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kitten section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_kitten_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:textColor="@color/clinical_ink_muted"
                        android:textSize="10sp"
                        tools:text="FOSTERS · 02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_kitten_card_header"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.04"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:text="SAME LITTER"
                        android:textColor="@color/clinical_sage"
                        android:textSize="8sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/button_add_kitten"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_sage_button"
                    android:drawablePadding="5dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.04"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="ADD KITTEN"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Horizontal kitten cards scroll -->
            <HorizontalScrollView
                android:id="@+id/scroll_kittens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layout_kitten_cards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Kitten cards are added programmatically -->

                    <!-- Ghost add card -->
                    <LinearLayout
                        android:id="@+id/card_ghost_add"
                        android:layout_width="80dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_ghost_add_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:minHeight="200dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:letterSpacing="0.04"
                            android:lineSpacingMultiplier="1.4"
                            android:text="ADD"
                            android:textColor="@color/clinical_sage"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- Sticky bottom bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/clinical_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="@color/clinical_ink_muted"
            app:cornerRadius="7dp"
            app:strokeColor="@color/clinical_line" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_create"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Create 2 Kittens"
            android:textColor="@color/white"
            app:backgroundTint="@color/clinical_sage"
            app:cornerRadius="7dp" />
    </LinearLayout>
</LinearLayout>
