<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/clinical_bg"
    android:orientation="vertical"
    tools:context=".KittenDetailFragment">

    <!-- Chart header bar -->

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/clinical_line" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="72dp">

            <!-- Patient header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/clinical_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/image_profile"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@color/clinical_sage_tint"
                        android:contentDescription="@string/profile_image_desc"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/default_kitten_profile" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/text_kitten_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAllCaps="true"
                            android:textColor="@color/clinical_ink"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="kitty" />

                        <TextView
                            android:id="@+id/text_kitten_breed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/clinical_ink_soft"
                            android:textSize="12sp"
                            tools:text="&quot;chungus&quot; · A1347542" />

                        <!-- Info chips row -->
                        <LinearLayout
                            android:id="@+id/layout_info_chips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_export"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="12dp"
                    android:layout_marginEnd="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="36dp"
                    android:text="@string/export_button"
                    android:textAllCaps="false"
                    android:textColor="@color/clinical_sage"
                    android:textSize="12sp" />
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/clinical_line" />

            <!-- Vitals chart card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/clinical_surface"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/clinical_line"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- KPI strip for vitals -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal"
                            android:paddingBottom="10dp">

                            <!-- Weight KPI -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.05"
                                    android:text="@string/stat_weight"
                                    android:textColor="@color/clinical_ink_muted"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/text_current_weight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/clinical_ink"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="400g" />

                                <TextView
                                    android:id="@+id/text_weight_trend"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/clinical_amber"
                                    android:textSize="9sp"
                                    tools:text="-5g exp" />
                            </LinearLayout>

                            <!-- Stool KPI (placeholder) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="2"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.05"
                                    android:text="@string/stat_stool_avg"
                                    android:textColor="@color/clinical_ink_muted"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/text_stool_avg"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/clinical_sage"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="4.6/7" />

                                <TextView
                                    android:id="@+id/text_stool_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/in_range"
                                    android:textColor="@color/clinical_sage"
                                    android:textSize="9sp" />
                            </LinearLayout>

                            <!-- Events KPI (placeholder) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.05"
                                    android:text="@string/stat_events"
                                    android:textColor="@color/clinical_ink_muted"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/text_events_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:fontFamily="monospace"
                                    android:textColor="@color/clinical_crimson"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    tools:text="0" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/last_14d"
                                    android:textColor="@color/clinical_ink_muted"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clinical_line_soft" />

                        <!-- Weight chart area -->
                        <com.example.fosterconnect.foster.VitalsChartView
                            android:id="@+id/vitals_chart"
                            android:layout_width="match_parent"
                            android:layout_height="190dp"
                            android:layout_marginTop="8dp" />

                        <!-- Legend -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="14dp"
                                    android:layout_height="2dp"
                                    android:background="@color/clinical_crimson" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/legend_weight"
                                    android:textColor="@color/clinical_ink_soft"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="14dp"
                                    android:layout_height="2dp"
                                    android:background="@color/clinical_amber" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/legend_stool"
                                    android:textColor="@color/clinical_ink_soft"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="7dp"
                                    android:layout_height="7dp"
                                    android:background="@drawable/legend_dot_crimson" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:fontFamily="monospace"
                                    android:text="@string/legend_vomiting"
                                    android:textColor="@color/clinical_ink_soft"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Zone explainer -->

                        <!-- Log buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_add_weight"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:text="@string/log_weight"
                                android:textSize="12sp"
                                app:backgroundTint="@color/clinical_sage"
                                app:cornerRadius="5dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_log_stool"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="6dp"
                                android:layout_weight="1"
                                android:text="@string/log_stool"
                                android:textColor="@color/clinical_ink_soft"
                                android:textSize="12sp"
                                app:cornerRadius="5dp"
                                app:strokeColor="@color/clinical_line" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_log_event"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:paddingHorizontal="12dp"
                                android:text="@string/log_event"
                                android:textSize="12sp"
                                app:backgroundTint="@color/clinical_crimson"
                                app:cornerRadius="5dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Treatment ledger card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/clinical_surface"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/clinical_line"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Ledger header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/clinical_sage_tint"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/text_treatment_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:letterSpacing="0.08"
                                    android:text="@string/treatment_ledger_label"
                                    android:textColor="@color/clinical_ink_muted"
                                    android:textSize="10sp" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_schedule_treatment"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:fontFamily="monospace"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:letterSpacing="0.05"
                                android:minHeight="28dp"
                                android:paddingHorizontal="12dp"
                                android:text="@string/schedule"
                                android:textColor="@color/clinical_sage"
                                android:textSize="10sp"
                                android:visibility="gone"
                                app:cornerRadius="4dp"
                                app:strokeColor="@color/clinical_sage"
                                app:strokeWidth="1dp" />

                        </LinearLayout>

                        <View
                            android:id="@+id/divider_table_top"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clinical_line" />

                        <!-- Table header -->
                        <LinearLayout
                            android:id="@+id/layout_table_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.3"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.05"
                                android:text="@string/col_protocol"
                                android:textColor="@color/clinical_ink_muted"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.05"
                                android:text="@string/col_dose"
                                android:textColor="@color/clinical_ink_muted"
                                android:textSize="10sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.8"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.05"
                                android:text="@string/col_due"
                                android:textColor="@color/clinical_ink_muted"
                                android:textSize="10sp" />

                            <View
                                android:layout_width="70dp"
                                android:layout_height="0dp" />
                        </LinearLayout>

                        <View
                            android:id="@+id/divider_table_bottom"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clinical_line" />

                        <!-- Treatment rows container -->
                        <LinearLayout
                            android:id="@+id/layout_treatment_schedule"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Medications section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/clinical_surface"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/clinical_line"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Medications header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/clinical_sage_tint"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="12dp">

                            <TextView
                                android:id="@+id/text_medications_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.08"
                                android:text="@string/medications_label_upper"
                                android:textColor="@color/clinical_ink_muted"
                                android:textSize="10sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_add_medication"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:fontFamily="monospace"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:letterSpacing="0.05"
                                android:minHeight="28dp"
                                android:paddingHorizontal="12dp"
                                android:text="@string/add"
                                android:textColor="@color/clinical_sage"
                                android:textSize="10sp"
                                app:cornerRadius="4dp"
                                app:strokeColor="@color/clinical_sage"
                                app:strokeWidth="1dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/clinical_line" />

                        <!-- Medication rows container -->
                        <LinearLayout
                            android:id="@+id/layout_medications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Complete foster case button (hold to confirm) -->
                <com.example.fosterconnect.foster.HoldToConfirmButton
                    android:id="@+id/button_mark_adopted"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/transparent" />

                <!-- Reopen foster case button (archive mode) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_reopen_case"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/reopen_foster_case"
                    android:textColor="@color/clinical_sage"
                    android:visibility="gone"
                    app:cornerRadius="5dp"
                    app:strokeColor="@color/clinical_sage" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
