<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp">

    <!-- Name -->
    <TextView
        android:id="@+id/text_med_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/clinical_ink"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="Ponazuril" />

    <!-- Day number (active only) -->
    <TextView
        android:id="@+id/text_med_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="monospace"
        android:textColor="@color/clinical_sage"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="Day 3" />

    <!-- Instructions -->
    <TextView
        android:id="@+id/text_med_instructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/clinical_ink_soft"
        android:textSize="12sp"
        android:visibility="gone"
        tools:text="0.3ml once daily" />

    <!-- Date range -->
    <TextView
        android:id="@+id/text_med_dates"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace"
        android:textColor="@color/clinical_ink_muted"
        android:textSize="10sp"
        tools:text="Started: April 10, 2026" />


</LinearLayout>
